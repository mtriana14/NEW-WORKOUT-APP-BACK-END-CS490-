{
  "info": {
    "name": "Fitness App API",
    "description": "API collection for Fitness App - Coach and Admin features",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Coach Availability",
      "item": [
        {
          "name": "Set Coach Availability",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/coach/availability", "host": ["{{base_url}}"], "path": ["coach", "availability"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"coach_id\": 1,\n  \"slots\": [\n    { \"day_of_week\": \"monday\", \"start_time\": \"09:00:00\", \"end_time\": \"17:00:00\", \"is_available\": true },\n    { \"day_of_week\": \"wednesday\", \"start_time\": \"09:00:00\", \"end_time\": \"17:00:00\", \"is_available\": true },\n    { \"day_of_week\": \"friday\", \"start_time\": \"09:00:00\", \"end_time\": \"13:00:00\", \"is_available\": true }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get Coach Availability",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/coach/availability/1", "host": ["{{base_url}}"], "path": ["coach", "availability", "1"] }
          }
        }
      ]
    },
    {
      "name": "Client Requests",
      "item": [
        {
          "name": "Get Pending Requests for Coach",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/coach/1/requests", "host": ["{{base_url}}"], "path": ["coach", "1", "requests"] }
          }
        },
        {
          "name": "Accept Client Request",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/coach/requests/1/respond", "host": ["{{base_url}}"], "path": ["coach", "requests", "1", "respond"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"accepted\"\n}"
            }
          }
        },
        {
          "name": "Decline Client Request",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/coach/requests/1/respond", "host": ["{{base_url}}"], "path": ["coach", "requests", "1", "respond"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"declined\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin - Exercise Database",
      "item": [
        {
          "name": "Get All Exercises",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/admin/exercises", "host": ["{{base_url}}"], "path": ["admin", "exercises"] }
          }
        },
        {
          "name": "Create Exercise",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/admin/exercises", "host": ["{{base_url}}"], "path": ["admin", "exercises"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bench Press\",\n  \"description\": \"A compound upper body exercise.\",\n  \"muscle_group\": \"chest\",\n  \"equipment\": \"barbell\",\n  \"difficulty\": \"intermediate\",\n  \"instructions\": \"Lie on bench, lower bar to chest then press up.\",\n  \"admin_id\": 1\n}"
            }
          }
        },
        {
          "name": "Update Exercise",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/admin/exercises/1", "host": ["{{base_url}}"], "path": ["admin", "exercises", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description for this exercise.\",\n  \"difficulty\": \"advanced\"\n}"
            }
          }
        },
        {
          "name": "Delete Exercise",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/admin/exercises/1", "host": ["{{base_url}}"], "path": ["admin", "exercises", "1"] }
          }
        }
      ]
    },
    {
      "name": "Admin - Coach Registrations",
      "item": [
        {
          "name": "Get All Coaches",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/admin/coaches", "host": ["{{base_url}}"], "path": ["admin", "coaches"] }
          }
        },
        {
          "name": "Get Pending Coaches",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/admin/coaches/pending", "host": ["{{base_url}}"], "path": ["admin", "coaches", "pending"] }
          }
        },
        {
          "name": "Approve Coach Registration",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/admin/coaches/2/process", "host": ["{{base_url}}"], "path": ["admin", "coaches", "2", "process"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"approved\"\n}"
            }
          }
        },
        {
          "name": "Reject Coach Registration",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/admin/coaches/2/process", "host": ["{{base_url}}"], "path": ["admin", "coaches", "2", "process"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"rejected\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin - Coach Management",
      "item": [
        {
          "name": "Suspend Coach",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{base_url}}/admin/coaches/1/suspend", "host": ["{{base_url}}"], "path": ["admin", "coaches", "1", "suspend"] }
          }
        },
        {
          "name": "Reactivate Coach",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{base_url}}/admin/coaches/1/reactivate", "host": ["{{base_url}}"], "path": ["admin", "coaches", "1", "reactivate"] }
          }
        },
        {
          "name": "Disable Coach Permanently",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{base_url}}/admin/coaches/1/disable", "host": ["{{base_url}}"], "path": ["admin", "coaches", "1", "disable"] }
          }
        }
      ]
    },
    {
      "name": "Admin - Payment Dashboard",
      "item": [
        {
          "name": "Get Payment Summary",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/admin/payments/summary", "host": ["{{base_url}}"], "path": ["admin", "payments", "summary"] }
          }
        },
        {
          "name": "Get All Payments",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/admin/payments?page=1&per_page=10", "host": ["{{base_url}}"], "path": ["admin", "payments"], "query": [{ "key": "page", "value": "1" }, { "key": "per_page", "value": "10" }] }
          }
        },
        {
          "name": "Get Coach Payment Summary",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/admin/payments/coach/1", "host": ["{{base_url}}"], "path": ["admin", "payments", "coach", "1"] }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get All User Notifications",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/notifications/user/1", "host": ["{{base_url}}"], "path": ["notifications", "user", "1"] }
          }
        },
        {
          "name": "Get Unread Notifications",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/notifications/user/1/unread", "host": ["{{base_url}}"], "path": ["notifications", "user", "1", "unread"] }
          }
        },
        {
          "name": "Mark Notification as Read",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{base_url}}/notifications/1/read", "host": ["{{base_url}}"], "path": ["notifications", "1", "read"] }
          }
        },
        {
          "name": "Mark All Notifications as Read",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{base_url}}/notifications/user/1/read-all", "host": ["{{base_url}}"], "path": ["notifications", "user", "1", "read-all"] }
          }
        },
        {
          "name": "Send Notification",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/notifications", "host": ["{{base_url}}"], "path": ["notifications"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"title\": \"Test Notification\",\n  \"message\": \"This is a test notification.\",\n  \"type\": \"system\"\n}"
            }
          }
        },
        {
          "name": "Delete Notification",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/notifications/1", "host": ["{{base_url}}"], "path": ["notifications", "1"] }
          }
        }
      ]
    }
  ]
}